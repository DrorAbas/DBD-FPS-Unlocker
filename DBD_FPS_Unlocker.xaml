<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindow"
        Title="DBD FPS Unlocker v1.0.0"
        Width="920" Height="790"
        MinWidth="820" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#08090B"
        Foreground="#F8FAFC"
        FontFamily="Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- HebaniGrab-inspired palette -->
        <SolidColorBrush x:Key="Surface900Brush" Color="#08090B"/>
        <SolidColorBrush x:Key="Surface800Brush" Color="#111317"/>
        <SolidColorBrush x:Key="Surface700Brush" Color="#191C21"/>
        <SolidColorBrush x:Key="Surface600Brush" Color="#292D34"/>
        <SolidColorBrush x:Key="Surface400Brush" Color="#8F989F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#B51E32"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#D82B43"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#E05261"/>
        <SolidColorBrush x:Key="NeonBrush" Color="#C21F35"/>
        <SolidColorBrush x:Key="NeonDimBrush" Color="#E05261"/>
        <SolidColorBrush x:Key="BadBrush" Color="#E14A5C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A4ABB1"/>
        <SolidColorBrush x:Key="GlassBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="GlassStrongBrush" Color="#1CFFFFFF"/>
        <SolidColorBrush x:Key="GlassBorderBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="GlassBorderHoverBrush" Color="#36FFFFFF"/>
        <SolidColorBrush x:Key="PaperBrush" Color="#FFFFFF"/>

        <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0D0F12" Offset="0"/>
            <GradientStop Color="#060709" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D82B43" Offset="0"/>
            <GradientStop Color="#7D101D" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientHover" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F04459" Offset="0"/>
            <GradientStop Color="#AC182A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TitleGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F3F4F6" Offset="0"/>
            <GradientStop Color="#D82B43" Offset="0.52"/>
            <GradientStop Color="#87111F" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="SoftShadow"
                          Color="#000000"
                          BlurRadius="24"
                          ShadowDepth="5"
                          Opacity="0.34"/>

        <DropShadowEffect x:Key="AccentGlow"
                          Color="#B51E32"
                          BlurRadius="25"
                          ShadowDepth="0"
                          Opacity="0.58"/>

        <DropShadowEffect x:Key="NeonGlow"
                          Color="#C21F35"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.46"/>

        <DropShadowEffect x:Key="CyanGlow"
                          Color="#E05261"
                          BlurRadius="16"
                          ShadowDepth="0"
                          Opacity="0.35"/>

        <DropShadowEffect x:Key="RedGlow"
                          Color="#B51E32"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.55"/>

        <!-- Delayed help popup: shown by PowerShell near the mouse cursor -->
        <Style x:Key="DbDToolTipStyle" TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Placement" Value="MousePoint"/>
            <Setter Property="HorizontalOffset" Value="16"/>
            <Setter Property="VerticalOffset" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="#F20A0B0E"
                                BorderBrush="#8AC21F35"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="15"
                                MaxWidth="430"
                                Effect="{StaticResource SoftShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="13"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{StaticResource AccentGradient}"
                                        CornerRadius="2"/>
                                <ContentPresenter Grid.Column="2"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HelpIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="#16FFFFFF"/>
            <Setter Property="BorderBrush" Value="#72B51E32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <!-- Glass buttons -->
        <Style x:Key="GlassButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource GlassStrongBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource GlassBorderHoverBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource GlassButton}"/>

        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
            <Setter Property="BorderBrush" Value="#70B51E32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Padding" Value="20,13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource AccentGlow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentGradientHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetButton" TargetType="{x:Type Button}" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBoxItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#42B51E32"/>
                                <Setter Property="Foreground" Value="{StaticResource NeonBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboToggle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                CornerRadius="12">
                            <Grid>
                                <ContentPresenter Margin="13,5,38,5"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"
                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>
                                <Path Width="10"
                                      Height="6"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,14,0"
                                      Stretch="Fill"
                                      Fill="{StaticResource NeonBrush}"
                                      Data="M 0 0 L 5 5 L 10 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#55FFFFFF"/>
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Style="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                        MaxHeight="270"
                                        Background="#F21A1A33"
                                        BorderBrush="#35FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4"
                                        Effect="{StaticResource SoftShadow}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inputs -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource NeonBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                <Setter TargetName="InputBorder" Property="Effect" Value="{StaticResource CyanGlow}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider -->
        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Ellipse x:Name="ThumbCircle"
                                 Fill="{StaticResource NeonBrush}"
                                 Stroke="#E6FFFFFF"
                                 StrokeThickness="2"
                                 Effect="{StaticResource NeonGlow}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbCircle" Property="Fill" Value="#EDFF85"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbCircle" Property="Fill" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="30" VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="6"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="3"
                                                        Background="{StaticResource AccentGradient}"
                                                        Effect="{StaticResource AccentGlow}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="6"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="3"
                                                        Background="#28FFFFFF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox -->
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="18" Height="18"
                                    CornerRadius="5"
                                    Background="#16FFFFFF"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1.2"
                                    VerticalAlignment="Top"
                                    Margin="0,1,0,0">
                                <Path x:Name="CheckMark"
                                      Visibility="Collapsed"
                                      Data="M 2 8 L 6 12 L 14 3"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="5,0,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource NeonBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource NeonBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio button -->
        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RadioRing"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="#12FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1.4"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0">
                                <Ellipse x:Name="RadioDot"
                                         Width="8" Height="8"
                                         Fill="{StaticResource NeonBrush}"
                                         Visibility="Collapsed"
                                         Effect="{StaticResource NeonGlow}"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="5,0,0,0"
                                              VerticalAlignment="Top"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioRing" Property="BorderBrush" Value="{StaticResource NeonBrush}"/>
                                <Setter TargetName="RadioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioRing" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cards and typography -->
        <Style x:Key="Card" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style x:Key="InnerCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,11"/>
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="{x:Type Expander}">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowGradient}">
        <!-- Static aurora background, matching HebaniGrab's blob palette -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="560" Height="560" Canvas.Right="-120" Canvas.Top="-185" Opacity="0.38">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#A06E0F1B" Offset="0"/>
                        <GradientStop Color="#006E0F1B" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="65"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="510" Height="510" Canvas.Left="-150" Canvas.Bottom="-190" Opacity="0.32">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#80545E66" Offset="0"/>
                        <GradientStop Color="#00545E66" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="360" Height="360" Canvas.Left="310" Canvas.Top="260" Opacity="0.18">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#806F0F1A" Offset="0"/>
                        <GradientStop Color="#006F0F1A" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="68"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="280" Height="280" Canvas.Left="490" Canvas.Top="60" Opacity="0.13">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#705B141E" Offset="0"/>
                        <GradientStop Color="#005B141E" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="62"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="DBD FPS Unlocker"
                               FontSize="31"
                               FontWeight="Black"
                               FontStyle="Italic"
>
                        <TextBlock.Foreground>
                            <StaticResource ResourceKey="TitleGradient"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <Border Width="74"
                            Height="5"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Margin="0,7,0,0"
                            Background="{StaticResource AccentGradient}"
                            Effect="{StaticResource AccentGlow}"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="Focused, safe FPS configuration for Dead by Daylight"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,9,0,0"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                        <TextBlock x:Name="LanguageLabel"
                                   Text="Language"
                                   Foreground="{StaticResource Surface400Brush}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="LanguageHelpIcon" Style="{StaticResource HelpIconStyle}">
                            <TextBlock Text="?"
                                       Foreground="#F1F3F4"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <ComboBox x:Name="LanguageCombo" SelectedIndex="0">
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                        <ComboBoxItem Tag="he">עברית</ComboBoxItem>
                        <ComboBoxItem Tag="es">Español</ComboBoxItem>
                        <ComboBoxItem Tag="de">Deutsch</ComboBoxItem>
                        <ComboBoxItem Tag="fr">Français</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Status / installation -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="28" Height="28"
                            CornerRadius="14"
                            Background="#14D9FF2F"
                            BorderBrush="#35D9FF2F"
                            BorderThickness="1">
                        <Ellipse x:Name="StatusDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource NeonBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Effect="{StaticResource NeonGlow}"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Checking..."
                                   FontWeight="ExtraBold"
                                   FontSize="14"/>
                        <TextBlock x:Name="GameStateText"
                                   Text=""
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                            <TextBlock x:Name="ConfigLabel"
                                       Text="Game installation"
                                       Foreground="{StaticResource Surface400Brush}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="ConfigHelpIcon" Style="{StaticResource HelpIconStyle}">
                                <TextBlock Text="?"
                                           Foreground="#F1F3F4"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <ComboBox x:Name="ConfigCombo"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main scrollable content -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,7,0">
                <StackPanel>
                    <!-- FPS card -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="280"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                                    <TextBlock x:Name="TargetTitle"
                                               Text="Target FPS"
                                               FontSize="17"
                                               FontWeight="ExtraBold"
                                               Foreground="#FFFFFF"
                                               VerticalAlignment="Center"/>
                                    <Border x:Name="FpsHelpIcon" Style="{StaticResource HelpIconStyle}">
                                        <TextBlock Text="?"
                                                   Foreground="#F1F3F4"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="128"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#18FFFFFF"
                                            BorderBrush="#26FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="15"
                                            Effect="{StaticResource SoftShadow}">
                                        <TextBox x:Name="FpsTextBox"
                                                 Text="165"
                                                 FontSize="29"
                                                 FontWeight="Black"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FlowDirection="LeftToRight"
                                                 MaxLength="3"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="7"/>
                                    </Border>

                                    <Slider x:Name="FpsSlider"
                                            Grid.Column="2"
                                            Minimum="30"
                                            Maximum="360"
                                            Value="165"
                                            TickFrequency="30"
                                            IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <UniformGrid Columns="5" Margin="0,16,0,0">
                                    <Button x:Name="Preset120" Content="120" Style="{StaticResource PresetButton}"/>
                                    <Button x:Name="Preset144" Content="144" Style="{StaticResource PresetButton}"/>
                                    <Button x:Name="Preset165" Content="165" Style="{StaticResource PresetButton}"/>
                                    <Button x:Name="Preset240" Content="240" Style="{StaticResource PresetButton}"/>
                                    <Button x:Name="Preset360" Content="360" Style="{StaticResource PresetButton}" Margin="0"/>
                                </UniformGrid>
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="9"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="5"
                                                CornerRadius="3"
                                                Background="{StaticResource AccentGradient}"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock x:Name="DetectedTitle"
                                                       Text="Detected configuration"
                                                       FontWeight="ExtraBold"
                                                       VerticalAlignment="Center"/>
                                            <Border x:Name="DetectedHelpIcon" Style="{StaticResource HelpIconStyle}">
                                                <TextBlock Text="?"
                                                           Foreground="#F1F3F4"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="DetectedValues"
                                               Text="Waiting..."
                                               Foreground="#C9CEE0"
                                               TextWrapping="Wrap"
                                               LineHeight="21"
                                               FlowDirection="LeftToRight"/>
                                    <TextBlock x:Name="ActualFpsNote"
                                               Text="This verifies the files, not the FPS shown by the game."
                                               Foreground="{StaticResource Surface400Brush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,11,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Method and options -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="MethodTitle"
                                           Text="FPS method"
                                           Style="{StaticResource SectionTitle}"/>

                                <RadioButton x:Name="SafeMethodRadio"
                                             IsChecked="True"
                                             Margin="0,2,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="SafeMethodTitle"
                                                       Text="Standard — FPS limit only"
                                                       FontWeight="ExtraBold"
                                                       VerticalAlignment="Center"/>
                                            <Border x:Name="SafeHelpIcon" Style="{StaticResource HelpIconStyle}">
                                                <TextBlock Text="?"
                                                           Foreground="#F1F3F4"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock x:Name="SafeMethodDesc"
                                                   Text="Uses normal configuration values. Above 120 FPS may still remain capped."
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </RadioButton>

                                <Border Height="1" Background="#16FFFFFF" Margin="0,15,0,14"/>

                                <RadioButton x:Name="FixedMethodRadio">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="FixedMethodTitle"
                                                       Text="Experimental — changes engine timing"
                                                       FontWeight="ExtraBold"
                                                       VerticalAlignment="Center"/>
                                            <Border x:Name="FixedHelpIcon" Style="{StaticResource HelpIconStyle}">
                                                <TextBlock Text="?"
                                                           Foreground="#F1F3F4"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock x:Name="FixedMethodDesc"
                                                   Text="May bypass limits, but can affect game timing if the selected FPS is not maintained."
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="OptionsTitle"
                                           Text="Options"
                                           Style="{StaticResource SectionTitle}"/>

                                <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                                    <TextBlock x:Name="VsyncLabel"
                                               Text="In-game V-Sync"
                                               Foreground="{StaticResource Surface400Brush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Border x:Name="VsyncHelpIcon" Style="{StaticResource HelpIconStyle}">
                                        <TextBlock Text="?"
                                                   Foreground="#F1F3F4"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <ComboBox x:Name="VsyncCombo" SelectedIndex="0">
                                    <ComboBoxItem Tag="keep">Keep current setting</ComboBoxItem>
                                    <ComboBoxItem Tag="off">Off</ComboBoxItem>
                                    <ComboBoxItem Tag="on">On</ComboBoxItem>
                                </ComboBox>

                                <Border Height="1" Background="#16FFFFFF" Margin="0,16,0,15"/>

                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="LockFilesCheck"
                                              IsChecked="False"
                                              Content="Use Read-only only if DBD resets the value"/>
                                    <Border x:Name="ReadOnlyHelpIcon" Style="{StaticResource HelpIconStyle}">
                                        <TextBlock Text="?"
                                                   Foreground="#F1F3F4"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="LockFilesDesc"
                                           Text="Read-only is not dangerous, but settings changed inside DBD may not save."
                                           Style="{StaticResource MutedText}"
                                           FontSize="12"
                                           Margin="24,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Warning -->
                    <Border x:Name="WarningBorder"
                            Margin="0,14,0,0"
                            Background="#1EC21F35"
                            BorderBrush="#70B51E32"
                            BorderThickness="1"
                            CornerRadius="15"
                            Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="30" Height="30"
                                    CornerRadius="15"
                                    Background="#25C21F35"
                                    BorderBrush="#70B51E32"
                                    BorderThickness="1">
                                <TextBlock Text="!"
                                           FontSize="18"
                                           FontWeight="Black"
                                           Foreground="{StaticResource NeonBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="WarningText"
                                       Grid.Column="2"
                                       Text="Values above 120 FPS are experimental."
                                       TextWrapping="Wrap"
                                       Foreground="#F0CCD2"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Primary action -->
                    <Button x:Name="ApplyButton"
                            Content="Apply FPS settings"
                            Style="{StaticResource AccentButton}"
                            Margin="0,14,0,0"/>

                    <!-- Secondary actions -->
                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,14,0,0">
                        <UniformGrid Columns="5">
                            <Button x:Name="RefreshButton" Content="Refresh" Margin="0,0,8,0"/>
                            <Button x:Name="RestoreButton" Content="Restore latest" Margin="0,0,8,0"/>
                            <Button x:Name="UnlockButton" Content="Unlock files" Margin="0,0,8,0"/>
                            <Button x:Name="OpenConfigButton" Content="Open config" Margin="0,0,8,0"/>
                            <Button x:Name="OpenBackupsButton" Content="Open backups"/>
                        </UniformGrid>
                    </Border>

                    <!-- Log -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14">
                        <Expander x:Name="LogExpander"
                                  Header="Activity log"
                                  IsExpanded="False"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <TextBox x:Name="LogTextBox"
                                     Height="130"
                                     Margin="0,10,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     TextWrapping="NoWrap"
                                     FlowDirection="LeftToRight"
                                     Background="#55101020"/>
                        </Expander>
                    </Border>

                    <TextBlock x:Name="FooterText"
                               Text="Portable • No installation • No administrator rights • Windows 10/11"
                               Foreground="{StaticResource Surface400Brush}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,5"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>